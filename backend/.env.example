# Backend environment variables. Copy to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# Required. Your OpenAI API key, used for embeddings and answer generation.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional. Comma-separated list of browser origins allowed to call the API
# (CORS). Defaults to the local Vite dev server if unset.
# Example for production: https://your-domain.com,https://www.your-domain.com
ALLOWED_ORIGINS=http://localhost:5173
